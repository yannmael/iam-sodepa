# Copier ce fichier en .env et remplir les valeurs

# Django
SECRET_KEY=changez-moi-en-production
DEBUG=True
ALLOWED_HOSTS=portail.sodepa.local,localhost,127.0.0.1

# Base de données (SQLite par défaut, PostgreSQL en prod)
DATABASE_URL=sqlite:///db.sqlite3

# Keycloak — SSO utilisateurs
KEYCLOAK_URL=https://keycloak.sodepa.local:8080
KEYCLOAK_REALM=sodepa
KEYCLOAK_CLIENT_ID=portail-iam
KEYCLOAK_CLIENT_SECRET=VOTRE_SECRET_ICI

# Keycloak — API Admin (service account)
KEYCLOAK_ADMIN_CLIENT_ID=portail-iam-admin
KEYCLOAK_ADMIN_CLIENT_SECRET=VOTRE_SECRET_ADMIN_ICI
